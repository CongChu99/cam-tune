// CamTune — AI Camera Settings Advisor
// Full schema for all models.
// Uses PostgreSQL (Supabase). DB URL is provided via DATABASE_URL env variable.

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SensorSize {
  FULL_FRAME
  APS_C
  MFT
  ONE_INCH
  MEDIUM_FORMAT
  OTHER
}

enum UiMode {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LensType {
  PRIME
  ZOOM
}

enum LensSource {
  LENSFUN
  EXIF
  MANUAL
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                              String     @id @default(uuid())
  email                           String     @unique
  name                            String?
  passwordHash                    String?
  skillLevel                      SkillLevel @default(BEGINNER)
  uiMode                          UiMode     @default(BEGINNER)
  openaiApiKeyEncrypted           String?
  openaiModelId                   String?
  lightroomAccessTokenEncrypted   String?
  lightroomRefreshTokenEncrypted  String?
  lightroomTokenExpiry            DateTime?
  lightroomTokenIssuedAt          DateTime?
  captureOneAccessTokenEncrypted  String?
  captureOneRefreshTokenEncrypted String?
  captureOneTokenExpiry           DateTime?
  captureOneTokenIssuedAt         DateTime?
  createdAt                       DateTime   @default(now())

  cameraProfiles CameraProfile[]
  shootSessions  ShootSession[]
  settingsCards  SettingsCard[]
  savedCards     SavedCard[]
  likedCards     CardLike[]
  reportedCards        CardReport[]
  shootPlans           ShootPlan[]
  lensExifUnmatcheds   LensExifUnmatched[]
}

model CameraDatabase {
  id                  String     @id @default(uuid())
  brand               String
  model               String
  slug                String     @unique
  sensorSize          SensorSize
  pixelCountMp        Decimal?
  baseIso             Int
  maxUsableIso        Int
  maxNativeIso        Int
  ibis                Boolean    @default(false)
  ibisStops           Decimal?
  dualNativeIso       Boolean    @default(false)
  /// Comma-separated ISO values for dual native ISO (e.g. "800,12800").
  dualNativeIsoValues String?
  /// Maximum flash sync speed in 1/x seconds (e.g. 250 means 1/250s). Null if unknown.
  maxFlashSyncSpeed   Int?
  dynamicRangeEv      Decimal?
  releaseYear         Int?
  mount               String?
  updatedAt           DateTime   @updatedAt

  cameraProfiles CameraProfile[]
}

model CameraProfile {
  id               String   @id @default(uuid())
  userId           String
  brand            String
  model            String
  cameraDatabaseId String?
  isActive         Boolean  @default(false)
  isUserEntered    Boolean  @default(false)
  ibisVerified     Boolean  @default(false)
  /// JSON object for user overrides to camera database specs
  customOverrides  Json?
  createdAt        DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cameraDatabase CameraDatabase? @relation(fields: [cameraDatabaseId], references: [id])
  lensProfiles   LensProfile[]
  shootSessions  ShootSession[]

  /// Only one active profile per user — enforced at application layer.
  @@index([userId, isActive])
}

model LensProfile {
  id                 String      @id @default(uuid())
  cameraProfileId    String
  focalLengthMm      Int
  maxAperture        Decimal
  minAperture        Decimal
  isStabilized       Boolean     @default(false)
  stabilizationStops Decimal?
  focalLengthMinMm   Int?
  focalLengthMaxMm   Int?
  isVariableAperture Boolean     @default(false)
  maxApertureTele    Decimal?
  lensType           LensType?
  /// External Lensfun database identifier (e.g. "sony/sel50f18f"). Null for manual entries.
  lensfunId          String?
  source             LensSource?

  cameraProfile CameraProfile @relation(fields: [cameraProfileId], references: [id], onDelete: Cascade)
}

model ShootSession {
  id               String    @id @default(uuid())
  userId           String
  cameraProfileId  String
  lat              Decimal
  lng              Decimal
  locationName     String?
  startedAt        DateTime
  endedAt          DateTime?
  /// JSON snapshot of weather at time of session
  weatherSnapshot  Json
  /// JSON snapshot of sun position/angle data
  sunSnapshot      Json
  sceneType        String?
  /// AI-generated recommendation JSON (cached from AIRecommendation)
  aiRecommendation Json?
  /// Actual settings used (filled in after shoot)
  actualSettings   Json?
  /// Capture One offline sync queue — stores {pending: string[]} of session IDs awaiting retry
  captureOneSyncQueue Json?
  /// Rating 1–5
  userRating       Int?
  notes            String?
  isPlan           Boolean   @default(false)
  createdAt        DateTime  @default(now())

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  cameraProfile     CameraProfile      @relation(fields: [cameraProfileId], references: [id], onDelete: Restrict)
  aiRecommendations AIRecommendation[]
  settingsCards     SettingsCard[]

  @@index([userId])
  @@index([startedAt])
}

model AIRecommendation {
  id                  String   @id @default(uuid())
  sessionId           String
  modelId             String
  inputSignals        Json
  rawResponse         Json
  parsedSuggestions   Json
  /// Comma-separated confidence scores (e.g. "0.92,0.85,0.78")
  confidenceScores    String
  primarySignalDriver String?
  latencyMs           Int?
  createdAt           DateTime @default(now())

  session ShootSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SettingsCard {
  id                String   @id @default(uuid())
  userId            String
  sessionId         String?
  cameraModel       String
  lat               Decimal
  lng               Decimal
  locationName      String
  /// JSON settings object (shutter, aperture, ISO, etc.)
  settings          Json
  /// JSON weather conditions at time of card creation
  weatherConditions Json?
  photoUrl          String?
  caption           String?
  isPublic          Boolean  @default(false)
  likesCount        Int      @default(0)
  savesCount        Int      @default(0)
  isFlagged         Boolean  @default(false)
  createdAt         DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ShootSession? @relation(fields: [sessionId], references: [id])
  savedBy SavedCard[]
  likedBy CardLike[]
  reports CardReport[]

  @@index([userId])
  @@index([isPublic, createdAt])
}

model SavedCard {
  userId  String
  cardId  String
  savedAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  card SettingsCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@id([userId, cardId])
}

model CardLike {
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  card SettingsCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@id([userId, cardId])
}

model CardReport {
  id        String   @id @default(uuid())
  userId    String
  cardId    String
  reason    String?
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  card SettingsCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

model ShootPlan {
  id                String    @id @default(cuid())
  userId            String
  title             String
  description       String?
  plannedAt         DateTime
  latitude          Float
  longitude         Float
  locationName      String?
  sceneType         String
  predictedIso      Int?
  predictedAperture Float?
  predictedShutter  String?
  predictedWB       String?
  predictedMetering String?
  /// JSON snapshot of forecast weather conditions
  forecastSnapshot  String?
  notificationSent  Boolean   @default(false)
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([plannedAt])
}

/// Reference lens database seeded from Lensfun XML.
/// Not user-specific — serves as lookup for lens quick-add and EXIF matching.
model LensfunLens {
  id                String    @id @default(uuid())
  lensfunId         String    @unique
  manufacturer      String
  model             String
  focalLengthMinMm  Int
  focalLengthMaxMm  Int
  maxAperture       Decimal
  lensType          LensType  @default(PRIME)
  popularityWeight  Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([manufacturer])
  @@index([model])
  @@index([popularityWeight])
}

model LensExifUnmatched {
  id                 String   @id @default(uuid())
  rawLensModelString String
  userId             String
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

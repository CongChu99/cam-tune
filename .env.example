# =============================================================================
# CamTune — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env to version control.
# =============================================================================

# --- Database (Supabase PostgreSQL via Prisma) --------------------------------
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# --- NextAuth -----------------------------------------------------------------
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# The canonical URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# --- Supabase -----------------------------------------------------------------
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# --- Upstash Redis (rate limiting / caching) ----------------------------------
# Found in: Upstash Console > Database > REST API
UPSTASH_REDIS_REST_URL="https://YOUR_REDIS_ENDPOINT.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token-here"

# --- OpenAI (BYOK — users supply their own keys at runtime) -------------------
# Server-side default key (optional — only for server-side fallback if needed)
# OPENAI_API_KEY="sk-..."
